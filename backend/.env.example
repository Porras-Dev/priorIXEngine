# =============================================================
# PriorIX Backend — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# ── Database ─────────────────────────────────────────────────
# Development: SQLite (no installation required)
DATABASE_URL="file:./dev.db"

# Production: PostgreSQL
# DATABASE_URL="postgresql://priorix_user:password@localhost:5432/priorix?schema=public"

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-very-long-random-string-in-production"
JWT_EXPIRES_IN="8h"

# ── Firebase Cloud Messaging (optional) ──────────────────────
# Leave blank to disable push notifications
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"

# ── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"

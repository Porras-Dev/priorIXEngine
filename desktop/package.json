{
  "name": "priorix-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "PriorIX desktop app - Electron + React",
  "author": "PriorIX Contributors",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_RUN_AS_NODE= NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.priorix.desktop",
    "productName": "PriorIX",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!node_modules/**"]
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules"
      },
      { "from": "resources/node", "to": "node" },
      { "from": "../backend/prisma/production.db", "to": "backend/prisma/production.db" }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "axios": "^1.18.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.9.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.69.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}